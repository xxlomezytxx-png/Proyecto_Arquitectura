  "item": [
    {
      "name": "1. Ver Estado de Adaptadores (Status)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8006/adapters/status",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8006",
          "path": [
            "adapters",
            "status"
          ]
        },
        "description": "Verifica el estado inicial del Circuit Breaker, conteo de fallos y cantidad de elementos en caché."
      },
      "response": []
    },
    {
      "name": "2. Prueba Google Books (Cache Miss)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8006/adapters/test/google-books?isbn=9780131103627",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8006",
          "path": [
            "adapters",
            "test",
            "google-books"
          ],
          "query": [
            {
              "key": "isbn",
              "value": "9780131103627"
            }
          ]
        },
        "description": "Primera petición. Debería demorar el tiempo normal de red y retornar `cached: false`."
      },
      "response": []
    },
    {
