# ─────────────────────────────────────────────────────────
# Ebook-AiCommerce — Plantilla de variables de entorno
# Copia este archivo como .env:  cp .env.example .env
# ─────────────────────────────────────────────────────────

# URL interna del data-quality-module (dentro de Docker)
DATA_QUALITY_URL=http://data-quality-module:8007

# Database URL genérica (reemplazada por variables individuales por servicio en docker-compose)
# DATABASE_URL=postgres://bookflow:bookflow123@<db-host>:5432/<db-name>

# URL del inventory-service.
# No está en este proyecto → el data-quality-module usará mock automáticamente.
INVENTORY_SERVICE_URL=http://inventory-service:8002

# Los siguientes servicios no están en este proyecto.
# El bff-gateway los intentará contactar y devolverá 503 controlado.
AUTH_SERVICE_URL=http://auth-service:8001
CATALOG_SERVICE_URL=http://catalog-service:8003
CONFIG_MODULE_URL=http://config-module:8008
PRICING_SERVICE_URL=http://pricing-service:8005
ENRICHMENT_SERVICE_URL=http://ai-enrichment-service:8004
ORDER_SERVICE_URL=http://order-service:8010
ASSISTANT_SERVICE_URL=http://ai-assistant-service:8011
RECOMMENDATION_SERVICE_URL=http://recommendation-service:8012

# Database configuration
POSTGRES_USER=bookflow
POSTGRES_PASSWORD=bookflow123
DB_NAME_AUTH=auth_db
DB_NAME_INVENTORY=inventory_db
DB_NAME_CATALOG=catalog_db
DB_NAME_CONFIG=config_db
DB_NAME_PRICING=pricing_db
DB_NAME_ENRICHMENT=enrichment_db
DB_NAME_ORDER=order_db
DB_NAME_ASSISTANT=assistant_db
DB_NAME_AUDIT=audit_db

# JWT configuration
JWT_SECRET_KEY=bookflow-secret-key-sprint1-development-only
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
JWT_REFRESH_EXPIRE_MINUTES=10080

# eBay API configuration
EBAY_APP_ID=your-ebay-app-id-here

# Google Books API configuration
GOOGLE_BOOKS_API_KEY=your-google-books-api-key-here

# Frontend configuration
VITE_BFF_URL=http://localhost:8009
REACT_APP_BFF_URL=http://localhost:8009

# CORS — comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
